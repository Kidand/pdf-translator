# 复制为 .env 并填入你的 key
# 必填项
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# API 配置
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 翻译策略
# 是否开启思考模式（更准但更慢更贵），默认 false
THINKING_ENABLED=false
# 并发 LLM 请求数（建议 6~10），默认 6
TRANSLATE_CONCURRENCY=6
# 每批翻译的字符预算（避免单次请求过大），默认 2200
BATCH_CHAR_BUDGET=2200

# 预览策略
# 焦点页向后预取的页数窗口，默认 3
PREFETCH_PAGES=3

# 数据与缓存
# 翻译任务和缓存数据目录（默认 ./data）
DATA_DIR=./data
# LLM 请求超时时间（秒），默认 300.0
LLM_TIMEOUT=300.0
# 任务数据保留时长（小时，<=0 表示永不清理），默认 48
JOB_RETENTION_HOURS=48
